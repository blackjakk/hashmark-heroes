{
  "name": "hashmark-heroes",
  "version": "1.0.0",
  "description": "Hashmark Heroes \u2014 American football franchise simulator (vanilla JS, no build) with an optional MegaETH on-chain layer (Hardhat).",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy": "hardhat run scripts/deploy.js --network megaeth",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "node": "hardhat node",
    "seed": "hardhat run scripts/seed.js --network megaeth",
    "party": "node server/party.js"
  },
  "dependencies": {
    "@chainlink/contracts": "1.3.0",
    "@openzeppelin/contracts": "5.0.2",
    "dotenv": "^17.4.2",
    "ethers": "^6.9.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.0"
  }
}
